# FastAPI runtime settings.
DATA_DIR=./data
SESSION_MAX_AGE_SECONDS=28800
COOKIE_SECURE=0

# Optional local Node development port. Production FastAPI ignores this.
PORT=3000

# Initial account passwords used only when data/employees.json is first created.
# Set strong private values in your local .env file.
ADMIN_INITIAL_PASSWORD=
CUSTOMER_INITIAL_PASSWORD=
STAFF_INITIAL_PASSWORD=

# DashScope / Qwen OpenAI-compatible API settings.
DASHSCOPE_API_KEY=
QWEN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
QWEN_MODEL=qwen-plus
