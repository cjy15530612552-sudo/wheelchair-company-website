# FastAPI runtime settings.
DATA_DIR=./data
SESSION_MAX_AGE_SECONDS=28800
COOKIE_SECURE=0

# Optional local Node development port. Production FastAPI ignores this.
PORT=3000

# Initial account passwords used only when data/employees.json is first created.
# Set strong private values in your local .env file.
ADMIN_INITIAL_PASSWORD=
CUSTOMER_INITIAL_PASSWORD=
STAFF_INITIAL_PASSWORD=

# DashScope / Qwen OpenAI-compatible API settings.
DASHSCOPE_API_KEY=
QWEN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
QWEN_MODEL=qwen-plus

# Optional Tencent Cloud SMS settings. If any value is missing, the backend
# uses development mode and prints SMS verification codes to the server log.
TENCENTCLOUD_SECRET_ID=
TENCENTCLOUD_SECRET_KEY=
TENCENT_SMS_SDK_APP_ID=
TENCENT_SMS_SIGN_NAME=
TENCENT_SMS_TEMPLATE_ID=
